# Local model endpoint placeholder, e.g. LM Studio OpenAI-compatible server.
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=qwen2.5-vl-7b-instruct

# Optional cloud fallback placeholder. Not required for V1.
GEMINI_API_KEY=

# Perception runtime.
DIFF_THRESHOLD=0.02
POLL_INTERVAL_SECONDS=0.5
OCR_CHAR_LIMIT=3000
ENABLE_DESKTOP_ACTIONS=false
