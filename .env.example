# Main vision brain: speed + low cost.
DEFAULT_VISION_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Reasoning fallback.
XAI_API_KEY=
GROK_MODEL=grok-4.3

# Local model is disabled for V1. Use later for offline/private mode.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=

# Perception runtime.
DIFF_THRESHOLD=0.02
POLL_INTERVAL_SECONDS=0.5
OCR_CHAR_LIMIT=3000
ENABLE_DESKTOP_ACTIONS=false
